# ============================================================================
# EdinTech-RAG Environment Configuration
# ============================================================================
# Copy this file to .env and adjust values for your setup.

# ---------------------------------------------------------------------------
# PostgreSQL (pgvector)
# ---------------------------------------------------------------------------
POSTGRES_USER=edintech
POSTGRES_PASSWORD=password
POSTGRES_DB=edintechrag
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# Ollama — embedding model + optional generation backend
# For Docker Compose: http://ollama:11434 (internal network)
# For local dev / llama_cpp backend: use host.docker.internal or localhost
# ---------------------------------------------------------------------------
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_PORT=11434

# Embedding model (always Ollama)
EMBED_MODEL=qwen3-embedding:0.6b

# Generation model used when GEN_BACKEND=ollama
GENERATION_MODEL=rnj-1:8b

# Enable extended thinking by default (Ollama only)
OLLAMA_THINK=true

# Vision model for image/diagram description in PDFs (optional)
# Set to a multimodal Ollama model, e.g. llava:7b or minicpm-v:8b
# Leave empty to skip image description (presence will still be noted)
VISION_MODEL=llava:7b

# ---------------------------------------------------------------------------
# Generation backend
#   ollama      — use Ollama /api/chat endpoint (default)
#   llama_cpp   — use llama.cpp server /v1/chat/completions endpoint
# ---------------------------------------------------------------------------
GEN_BACKEND=ollama

# ---------------------------------------------------------------------------
# llama.cpp server settings (only used when GEN_BACKEND=llama_cpp)
# ---------------------------------------------------------------------------
LLAMA_SERVER_URL=http://localhost:8080
LLAMA_PORT=8080

# Path to GGUF model file on the host (for docker-compose llama-server service)
MODEL_PATH=/home/edinj/llm-models
MODEL_FILE=qwen3-27b.Q4_K_M.gguf

# ---------------------------------------------------------------------------
# API server
# ---------------------------------------------------------------------------
APP_PORT=8001
UVICORN_RELOAD=false
